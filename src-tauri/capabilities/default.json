{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all windows",
  "windows": ["main", "screen"],
  "remote": {
    "urls": ["http://*", "https://*"]
  },
  "permissions": [
    "core:default",
    "opener:default",
    "core:webview:allow-create-webview-window",
    "allow-dashboard-commands"
  ]
}
